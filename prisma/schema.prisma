generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String       @id @default(cuid())
  email     String       @unique
  username  String       @unique
  gender    USER_GENDER? @default(MALE)
  avatarId  String?
  isDeleted Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userMeasurement Json? // For detailed { height: 90, wight: 70, usualSize: "M" }

  avatar   File?         @relation("UserAvatar", fields: [avatarId], references: [id])
  sessions Session[]
  outfits  Outfit[]
  outlines UserOutline[]
}

model UserOutline {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // The AI context
  userPrompt String[] // "I have a date on Sunday @ 6pm"
  location   String? // Extracted: "Mall"
  startTime  DateTime? // Parsed: Sunday @ 6pm
  weather    Json? // Cached weather data for that time

  // Relationships
  outfits   Outfit[]    @relation("UserOutlineOutfits")
  cosmetics Cosmetics[]

  // 1-to-1 with Calendar
  calendarId String?   @unique
  calendar   Calendar? @relation(fields: [calendarId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Cosmetics {
  id       String  @id @default(cuid())
  name     String
  brand    String?
  type     String? // Lipstick, Eye Shadow, etc.
  imageUrl String?
  hexColor String? // For UI color swatches

  userOutlineId String?
  userOutline   UserOutline? @relation(fields: [userOutlineId], references: [id])

  createdAt DateTime @default(now())
}

model Calendar {
  id          String    @id @default(cuid())
  externalId  String? // ID from Google/iCal
  title       String
  description String?
  location    String?
  startTime   DateTime
  endTime     DateTime?

  userOutline UserOutline?

  createdAt DateTime @default(now())
}

model Session {
  id                String   @id @default(cuid())
  userId            String
  platform          String
  expiresAt         DateTime
  accessToken       String
  refreshToken      String   @unique
  provider          String?
  providerUserId    String?
  providerAvatarUrl String?

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model File {
  id           String  @id @default(cuid())
  filename     String
  originalName String?
  fileUrl      String
  thumbnailUrl String?
  mimeType     String?
  extension    String?
  size         Int?
  provider     String  @default("S3") // S3 or LOCAL
  bucket       String?
  path         String? // Key or local path
  metaData     Json? // For dimensions, dominant color, etc.

  createdAt DateTime @default(now())

  // Relations
  garment    Garment? @relation("GarmentFile")
  userAvatar User[]   @relation("UserAvatar")
}

model Garment {
  id          String  @id @default(cuid())
  name        String
  description String?
  imageUrl    String
  fileId      String  @unique
  file        File    @relation("GarmentFile", fields: [fileId], references: [id])

  garmentType GARMENT_TYPES[]
  fittingSlot FITTING_SLOT[]
  category    CATEGORY[]
  gender      GARMENT_GENDER  @default(UNISEX)
  layerLevel  LAYER_LEVEL     @default(BASE)
  silhouette  SILHOUETTE      @default(Regular)
  metaData    Json?

  outfits      GarmentInOutfit[]
  interactions Interaction[]
  tags         Tag[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  garments Garment[]
}

model Interaction {
  id        String  @id @default(cuid())
  type      String // LIKE, DISLIKE, TRY_ON
  garmentId String
  outfitId  String?

  garment Garment @relation(fields: [garmentId], references: [id])
  outfit  Outfit? @relation(fields: [outfitId], references: [id])

  createdAt DateTime @default(now())
}

model Outfit {
  id           String            @id @default(cuid())
  userId       String
  name         String
  description  String?
  isPublic     Boolean           @default(false)
  user         User              @relation(fields: [userId], references: [id])
  items        GarmentInOutfit[]
  interactions Interaction[]
  userOutlines UserOutline[]     @relation("UserOutlineOutfits")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GarmentInOutfit {
  id        String @id @default(cuid())
  garmentId String
  outfitId  String
  order     Int    @default(0)

  garment Garment @relation(fields: [garmentId], references: [id])
  outfit  Outfit  @relation(fields: [outfitId], references: [id])

  createdAt DateTime @default(now())
}

/// Represents the Z-index stacking order for garments on the mirror.
/// Lower levels (INNER) are rendered first, higher levels (OVER) are rendered last.
enum LAYER_LEVEL {
  INNER // 0: Undergarments, socks
  BASE // 1: T-shirts, light shirts, leggings
  MID // 2: Sweaters, hoodies, cardigans
  OUTER // 3: Jackets, coats, blazers
  OVER // 4: Scarves, raincoats, protective gear
}

/// Target gender for the garment classification.
enum GARMENT_GENDER {
  MALE
  FEMALE
  UNISEX
}

enum USER_GENDER {
  MALE
  FEMALE
}

/// Defines where on the body the garment or accessory is anchored.
/// Critical for the 2.5D rendering engine to position assets correctly.
enum FITTING_SLOT {
  None

  // Head & Face
  HeadGarment // Hats, beanies, helmets
  Glasses // Spectacles, sunglasses
  Earrings // Ear accessories

  // Torso & Legs
  UpperGarment // Tops, shirts, jackets
  LowerGarment // Pants, skirts, shorts
  FullGarment // Dresses, jumpsuits, overalls

  // Extremities
  FootGarment // Shoes, boots, sneakers

  // Accessories
  LeftHandAccessory
  RightHandAccessory
  NeckAccessory // Necklaces, ties, scarves
  WaistAccessory // Belts, chains
}

enum GARMENT_TYPES {
  None

  // Headwear
  Hat
  Beanie
  Cap
  Headband

  // Upper Body
  Shirt
  TShirt
  Polo
  Blouse
  Hoodie
  Sweater
  Jacket
  Coat
  Blazer

  // Lower Body
  Pants
  Jeans
  Shorts
  Skirt

  // Full Body
  Dress
  Jumpsuit
  Romper
  Suit

  // Footwear
  Shoes
  Sneakers
  Sandals
  Boots
  Heels
  Socks

  // Accessories
  Watch
  Belt
  Sunglasses
  Bag
  Backpack
  Necklace
  Bracelet
  Ring
  Earrings
  Scarf
  Gloves
  Traditional
  Cultural
  Uniform
}

enum CATEGORY {
  Streetwear // Urban-inspired fashion (hoodies, sneakers, oversized fits, hype culture)
  Casual // Everyday relaxed clothing (jeans, tees, simple outfits)
  Formal // Strict dress code outfits (suits, tuxedos, formal dresses)
  Business // Office/professional attire (blazers, slacks, business dresses)
  SmartCasual // Hybrid of casual + formal (polished but relaxed looks)

  Sportswear // Clothing designed for sports activities (jerseys, training gear)
  Activewear // Gym/workout-focused clothing (performance fabrics, leggings)
  Athleisure // Sport + lifestyle wear (leggings, joggers worn casually)

  Winterwear // Cold-weather clothing (coats, jackets, heavy layers)
  Summerwear // Hot-weather clothing (light fabrics, shorts, breathable outfits)
  Rainwear // Waterproof clothing (raincoats, waterproof jackets)
  Springwear // Spring-appropriate clothing (light layers, transitional pieces)
  Autumnwear // Autumn-appropriate clothing (warm layers, cozy textures)

  Vintage // Retro-inspired styles from past decades
  Minimalist // Clean, simple, neutral, low-design outfits
  Luxury // High-end fashion, premium brands, expensive styling
  AvantGarde // Experimental, artistic, runway-style fashion

  Traditional // Heritage or culturally rooted clothing (e.g. barong, kimono)
  Cultural // Broader cultural-inspired outfits (non-ceremonial ethnic wear)
  Uniform // Standardized outfits (school, military, work uniforms)
}

/// Describes the overall visual shape and fit appearance of a garment.
/// Used for outfit styling, silhouette matching, layering logic,
/// and AI recommendation scoring in the virtual styling system.
enum SILHOUETTE {
  /// Close-to-body fit.
  /// Example: Slim-fit t-shirt, fitted polo, skinny jeans.
  Slim

  /// Standard balanced fit.
  /// Example: Basic t-shirt, regular jeans, standard hoodie.
  Regular

  /// Slightly loose and comfortable fit.
  /// Example: Relaxed hoodie, loose trousers, casual sweatshirt.
  Relaxed

  /// Intentionally larger and loose silhouette.
  /// Example: Oversized streetwear tee, baggy hoodie, oversized jacket.
  Oversized

  /// Square and wide body structure.
  /// Usually shorter width-heavy proportions.
  /// Example: Boxy cropped tee, modern streetwear shirt.
  Boxy

  /// Shortened garment length.
  /// Example: Cropped hoodie, cropped jacket, cropped top.
  Cropped

  /// Extended vertical length.
  /// Example: Longline t-shirt, elongated coat, long cardigan.
  Longline

  /// Wide lower-body silhouette.
  /// Example: Wide-leg pants, loose trousers, baggy jeans.
  WideLeg

  /// Straight cut from top to bottom.
  /// Example: Straight jeans, straight trousers.
  Straight

  /// Narrows toward the bottom.
  /// Example: Tapered joggers, tapered pants.
  Tapered

  /// Soft, loose, and naturally draping shape.
  /// Example: Flowing dress, loose cardigan, chiffon skirt.
  Flowy

  /// Strong and defined shape with rigid form.
  /// Example: Blazer, tailored coat, structured jacket.
  Structured
}
