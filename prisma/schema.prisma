generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  username  String  @unique
  avatarId  String?
  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  avatar   File?     @relation("UserAvatar", fields: [avatarId], references: [id])
  sessions Session[]
  outfits  Outfit[]
}

model Session {
  id                String   @id @default(uuid())
  userId            String
  platform          String
  expiresAt         DateTime
  accessToken       String
  refreshToken      String   @unique
  provider          String?
  providerUserId    String?
  providerAvatarUrl String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model File {
  id           String  @id @default(uuid())
  filename     String?
  originalName String?
  fileUrl      String?
  thumbnailUrl String?
  mimeType     String?
  extension    String?
  size         Int?
  provider     String?
  bucket       String?
  path         String?
  metaData     Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  users    User[]    @relation("UserAvatar")
  garments Garment[] @relation("GarmentFile")
}

model Garment {
  id          String  @id @default(cuid())
  name        String
  description String?
  imageUrl    String
  fileId      String?
  file        File?   @relation("GarmentFile", fields: [fileId], references: [id])

  garmentType GARMENTTYPES      @default(None)
  fittingSlot FITINGSLOTS       @default(None)
  category    CATEGORY[]
  gender      GENDER            @default(UNISEX)
  layerLevel  LAYERLEVEL        @default(BASE)
  metaData    Json?
  outfits     GarmentInOutfit[]
  tags        Tag[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Tag {
  id   String @id @default(cuid())
  name String @unique

  garments Garment[]
}

model Outfit {
  id          String  @id @default(cuid())
  name        String
  description String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items        GarmentInOutfit[]
  interactions Interaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GarmentInOutfit {
  garmentId String
  outfitId  String
  order     Int    @default(0)

  garment Garment @relation(fields: [garmentId], references: [id])
  outfit  Outfit  @relation(fields: [outfitId], references: [id])

  @@id([garmentId, outfitId])
}

model Interaction {
  id       String  @id @default(cuid())
  message  String
  response String
  intent   String?

  outfitId String?
  outfit   Outfit? @relation(fields: [outfitId], references: [id])

  createdAt DateTime @default(now())
}

/// Represents the Z-index stacking order for garments on the mirror.
/// Lower levels (INNER) are rendered first, higher levels (OVER) are rendered last.
enum LAYERLEVEL {
  INNER // 0: Undergarments, socks
  BASE // 1: T-shirts, light shirts, leggings
  MID // 2: Sweaters, hoodies, cardigans
  OUTER // 3: Jackets, coats, blazers
  OVER // 4: Scarves, raincoats, protective gear
}

/// Target gender for the garment classification.
enum GENDER {
  MALE
  FEMALE
  UNISEX
}

/// Defines where on the body the garment or accessory is anchored.
/// Critical for the 2.5D rendering engine to position assets correctly.
enum FITINGSLOTS {
  None

  // Head & Face
  HeadGarment // Hats, beanies, helmets
  Glasses // Spectacles, sunglasses
  Earrings // Ear accessories

  // Torso & Legs
  UpperGarment // Tops, shirts, jackets
  LowerGarment // Pants, skirts, shorts
  FullGarment // Dresses, jumpsuits, overalls

  // Extremities
  FootGarment // Shoes, boots, sneakers

  // Accessories
  LeftHandAccessory
  RightHandAccessory
  NeckAccessory // Necklaces, ties, scarves
  WaistAccessory // Belts, chains
}

enum GARMENTTYPES {
  None

  // Headwear
  Hat
  Beanie
  Cap
  Headband

  // Upper Body
  Shirt
  TShirt
  Polo
  Blouse
  Hoodie
  Sweater
  Jacket
  Coat
  Blazer

  // Lower Body
  Pants
  Jeans
  Shorts
  Skirt

  // Full Body
  Dress
  Jumpsuit
  Romper
  Suit

  // Footwear
  Shoes
  Sneakers
  Sandals
  Boots
  Heels
  Socks

  // Accessories
  Watch
  Belt
  Sunglasses
  Bag
  Backpack
  Necklace
  Bracelet
  Ring
  Earrings
  Scarf
  Gloves
  Traditional
  Cultural
  Uniform
}

enum CATEGORY {
  Streetwear
  Casual
  Formal
  Business
  SmartCasual
  Sportswear
  Activewear
  Athleisure
  Winterwear
  Summerwear
  Rainwear
  Springwear
  Autumnwear
  Vintage
  Minimalist
  Luxury
  AvantGarde
}
