{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "MirrorApiLogGroups",
      "Effect": "Allow",
      "Action": ["logs:CreateLogGroup", "logs:DescribeLogStreams"],
      "Resource": "arn:aws:logs:*:*:log-group:/mirror-api/*"
    },
    {
      "Sid": "MirrorApiLogStreams",
      "Effect": "Allow",
      "Action": ["logs:CreateLogStream", "logs:PutLogEvents"],
      "Resource": "arn:aws:logs:*:*:log-group:/mirror-api/*:log-stream:*"
    }
  ]
}
