{
  "name": "node-postg-template",
  "version": "1.0.0",
  "description": "Production-ready Node.js/TypeScript boilerplate with Prisma and Express",
  "main": "dist/server.js",
  "license": "MIT",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node --files ./src/server.ts",
    "build": "tsc",
    "start": "node ./dist/server.js",
    "lint": "eslint src/**/*.ts --fix",
    "db:setup": "npx prisma generate && npx prisma migrate dev",
    "db:seed": "npx ts-node --files prisma/seed.ts",
    "format": "npm run lint && prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1053.0",
    "@aws-sdk/client-polly": "^3.1047.0",
    "@aws-sdk/client-s3": "^3.1043.0",
    "@aws-sdk/client-transcribe-streaming": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.1043.0",
    "@prisma/client": "^6.19.2",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.6.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.0.0",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "multer-s3": "^3.0.1",
    "openai": "^6.37.0",
    "prisma": "^6.19.2",
    "redis": "^5.11.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "winston": "^3.11.0",
    "zod": "^4.4.3"
  },
  "resolutions": {
    "@types/express-serve-static-core": "4.19.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/joi": "^17.2.2",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/multer": "^1.4.13",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.31.1",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.0.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3"
  }
}
