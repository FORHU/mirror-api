{
  "name": "node-postg-template",
  "version": "1.0.0",
  "description": "Production-ready Node.js/TypeScript boilerplate with Prisma and Express",
  "main": "dist/src/server.js",
  "license": "MIT",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node --files ./src/server.ts",
    "build": "tsc",
    "start": "node ./dist/src/server.js",
    "lint": "eslint src/**/*.ts --fix",
    "db:setup": "npx prisma generate && npx prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "axios": "^1.6.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^7.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "prisma": "^6.19.2",
    "redis": "^5.11.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.15",
    "@types/express": "^4.17.18",
    "@types/joi": "^17.2.2",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.8.3",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.0.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3"
  }
}
